#!/usr/bin/env bash
# .editorconfig hint: indent_style = space, indent_size = 4
# SPDX-License-Identifier: GPL-3.0-or-later
set -Eeuo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; NC='\033[0m'

checks_passed=0
checks_failed=0

# --- shellcheck ---
if command -v shellcheck &>/dev/null; then
    echo ":: shellcheck on all project .sh files..."
    if shellcheck .githooks/pre-commit lib/*.sh sui-control.sh build/*.sh templates/*.sh.tpl 2>&1; then
        echo -e "${GREEN}   shellcheck passed${NC}"
        ((checks_passed += 1))
    else
        echo -e "${RED}   shellcheck FAILED${NC}"
        ((checks_failed += 1))
    fi
else
    echo ":: shellcheck not found, skipping"
fi

# --- actionlint ---
if command -v actionlint &>/dev/null; then
    staged_actions="$(git diff --cached --name-only --diff-filter=ACM | grep '^\.github/workflows/.*\.yml$' || true)"
    if [[ -n "$staged_actions" ]]; then
        echo ":: actionlint on staged workflow files..."
        if echo "$staged_actions" | xargs -r actionlint 2>&1; then
            echo -e "${GREEN}   actionlint passed${NC}"
            ((checks_passed += 1))
        else
            echo -e "${RED}   actionlint FAILED${NC}"
            ((checks_failed += 1))
        fi
    elif [[ -d .github/workflows ]]; then
        echo ":: actionlint on all workflow files..."
        if actionlint 2>&1; then
            echo -e "${GREEN}   actionlint passed${NC}"
            ((checks_passed += 1))
        else
            echo -e "${RED}   actionlint FAILED${NC}"
            ((checks_failed += 1))
        fi
    else
        echo ":: no .github/workflows directory, skipping actionlint"
    fi
else
    echo ":: actionlint not found, skipping"
fi

# --- shellcheck on debian maintainer scripts ---
staged_deb="$(git diff --cached --name-only --diff-filter=ACM | grep '^build/debian/.*\\(postinst\\|prerm\\|postrm\\)$' || true)"
if [[ -n "$staged_deb" ]]; then
    echo ":: shellcheck on debian maintainer scripts..."
    if echo "$staged_deb" | xargs -r shellcheck 2>&1; then
        echo -e "${GREEN}   shellcheck passed${NC}"
        ((checks_passed += 1))
    else
        echo -e "${RED}   shellcheck FAILED${NC}"
        ((checks_failed += 1))
    fi
else
    echo ":: no debian maintainer scripts staged, skipping"
fi

# --- summary ---
if (( checks_failed > 0 )); then
    echo -e "${RED}${checks_failed} check(s) failed, aborting commit${NC}"
    exit 1
fi
